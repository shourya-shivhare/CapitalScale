# =============================================================================
# DEPENDENCIES & PACKAGE MANAGERS
# =============================================================================
node_modules/
**/node_modules/
.pnp
.pnp.js

# =============================================================================
# ENVIRONMENT VARIABLES & SECURE CREDENTIALS (CRITICAL PREVENTION)
# =============================================================================
# Excludes all environment variable files that contain secrets (API keys, MongoDB URIs, JWT secrets)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local
**/.env
**/.env.*

# Ignore package manager config secrets (e.g. NPM authentication tokens)
.npmrc
.yarnrc

# Ignore private keys, SSL certificates, and credentials
*.key
*.pem
*.cert
*.crt
*.pfx
*.p12
*.pkcs12
*.jks
*.keystore
*credentials*.json
*service-account*.json
jwt.secret
secret.key

# =============================================================================
# BUILD OUTPUTS & CACHES
# =============================================================================
dist/
**/dist/
build/
**/build/
.next/
out/
.cache/
.parcel-cache/
.eslintcache/
.tsbuildinfo

# =============================================================================
# LOGS & SYSTEM DIAGNOSTICS
# =============================================================================
logs/
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# LOCAL DATABASES & DATA DUMPS
# =============================================================================
*.db
*.sqlite
*.sqlite3
*.dump
*.sql
*.sql.gz
**/dump.rdb

# =============================================================================
# SYSTEM FILES & IDE CONFIGURATIONS
# =============================================================================
# OS Files
.DS_Store
Thumbs.db
desktop.ini
.directory

# IDEs (VS Code, WebStorm, etc.)
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.userosscache
*.sln.docstates

# =============================================================================
# PROJECT SPECIFIC TEMPORARY FILES
# =============================================================================
.temp/
tmp/
*.tiff
*.bmp
.docker/
coverage/
.nyc_output/
.jest-cache/
